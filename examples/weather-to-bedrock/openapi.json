{
  "openapi": "3.0.0",
  "info": {
    "title": "weather Actions",
    "description": "Action group schema for the weather Bedrock agent.",
    "version": "1.0.0"
  },
  "paths": {
    "/curl/run": {
      "post": {
        "operationId": "curl_run",
        "description": "Run curl commands",
        "x-agentshift-stub": true,
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "command": {
                    "type": "string",
                    "description": "The curl command to run."
                  },
                  "args": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Arguments passed to the command."
                  }
                },
                "required": [
                  "command"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Command output",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "stdout": {
                      "type": "string"
                    },
                    "stderr": {
                      "type": "string"
                    },
                    "exit_code": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}